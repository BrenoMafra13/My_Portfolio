{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "npm run build",
    "outputDir": "dist"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npm run preview -- --host --port 4173"
  },
  "services": [
    {
      "name": "portfolio",
      "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
      }
    }
  ]
}

